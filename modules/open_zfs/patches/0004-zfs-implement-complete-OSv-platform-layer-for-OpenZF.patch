+static int
+zfs_rename_check(znode_t *szp, znode_t *sdzp, znode_t *tdzp)
+{
+	zfsvfs_t	*zfsvfs = tdzp->z_zfsvfs;
+	znode_t		*zp, *zp1;
+	uint64_t	parent;
+	int		error = 0;
