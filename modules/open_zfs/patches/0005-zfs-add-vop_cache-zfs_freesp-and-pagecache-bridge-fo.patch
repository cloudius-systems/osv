index 10c84c4cd..7a0895877 100644
--- a/module/os/osv/zfs/zfs_vnops_os.c
+++ b/module/os/osv/zfs/zfs_vnops_os.c
@@ -1067,7 +1067,7 @@ zfs_vop_getattr(struct vnode *vp, struct vattr *vap)
 
 	/*
