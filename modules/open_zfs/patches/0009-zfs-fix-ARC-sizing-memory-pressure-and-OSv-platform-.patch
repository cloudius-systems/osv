+++ b/module/os/osv/zfs/zfs_dir.c
@@ -349,9 +349,15 @@ zfs_link_create(znode_t *dzp, const char *name, znode_t *zp, dmu_tx_t *tx,
     int flag)
 {
 	zfsvfs_t *zfsvfs = ZTOZSB(zp);
-	struct vnode *vp = ZTOV(zp);
 	uint64_t value;
-	int zp_is_dir = (vp != NULL && vp->v_type == VDIR);
+	/*
+	 * Use S_ISDIR(z_mode) rather than ZTOV(zp)->v_type because on OSv
