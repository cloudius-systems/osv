index a97436e96..6264de33b 100644
--- a/module/os/osv/zfs/vdev_disk.c
+++ b/module/os/osv/zfs/vdev_disk.c
@@ -79,6 +79,7 @@ vdev_disk_open(vdev_t *vd, uint64_t *psize, uint64_t *max_psize,
 	*max_psize = *psize = dvd->device->size;
 	*logical_ashift = highbit64(MAX(DEV_BSIZE, SPA_MINBLOCKSIZE)) - 1;
 	*physical_ashift = *logical_ashift;
+
 	return (0);
 }
 
diff --git a/module/os/osv/zfs/zfs_dir.c b/module/os/osv/zfs/zfs_dir.c
index 64612433e..4e5ae0a6c 100644
